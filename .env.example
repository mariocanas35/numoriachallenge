# ===================================================
# Numoria Challenge — Plantilla de variables de entorno
# ===================================================
# Copia este archivo a .env.local y llena los valores reales.
# NUNCA commitees .env.local. Solo .env.example.
#
# Convenciones:
# - Variables NEXT_PUBLIC_* se exponen al navegador. Usar SOLO para datos no sensibles.
# - El resto son server-only.
# - Cuando algo está marcado [DIFERIDO] significa que aún no se activa en MVP.
# ===================================================

# ---- Branding ----
NEXT_PUBLIC_BRAND_NAME="Numoria Challenge"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# ---- Supabase (Fase 1) ----
# Obtener en https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Database URLs (Fase 3+ para grader Python que conecta directo)
DATABASE_URL=""
DATABASE_POOLED_URL=""

# ---- Email (Fase 2 — SMTP Gmail) ----
# Cuenta confirmada: mimathonline@gmail.com
# Generar App Password en https://myaccount.google.com/apppasswords (requiere 2FA habilitado)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="mimathonline@gmail.com"
SMTP_PASS=""                     # [DIFERIDO] App Password de 16 chars cuando se active
SMTP_FROM_NAME="Numoria Challenge"
SMTP_FROM_EMAIL="mimathonline@gmail.com"
EMAIL_REPLY_TO="mimathonline@gmail.com"

# ---- IA (Fase 5) ----
# https://console.anthropic.com
ANTHROPIC_API_KEY=""             # [DIFERIDO]
ANTHROPIC_MODEL="claude-sonnet-4-6"
# https://platform.openai.com (fallback)
OPENAI_API_KEY=""                # [DIFERIDO]
OPENAI_MODEL="gpt-4o-mini"
# Hard caps para evitar costos descontrolados
AI_DAILY_USD_CAP="10"
AI_MONTHLY_USD_CAP="200"

# ---- Microservicio Grader Python (Fase 3) ----
# Railway: https://railway.app
GRADING_SERVICE_URL="http://localhost:8000"     # local dev
GRADING_SERVICE_TOKEN=""         # [DIFERIDO] JWT compartido para auth interna

# ---- Geolocalización + tasas de cambio ----
# https://exchangerate-api.com (1500 req/mes free)
EXCHANGE_RATE_API_KEY=""         # [DIFERIDO — Fase 2]
# Override manual del país en dev (HN, MX, BR, US, etc.)
DEV_COUNTRY_OVERRIDE=""

# ---- Cloudflare Turnstile (Fase 1, anti-bot en registro) ----
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""    # [DIFERIDO]
TURNSTILE_SECRET_KEY=""              # [DIFERIDO]

# ---- Storage / Assets (Cloudflare R2 - Fase 2) ----
R2_ACCOUNT_ID=""                 # [DIFERIDO]
R2_ACCESS_KEY_ID=""              # [DIFERIDO]
R2_SECRET_ACCESS_KEY=""          # [DIFERIDO]
R2_BUCKET_PUBLIC=""              # logos escolares, avatars, etc.
R2_BUCKET_PRIVATE=""             # certificados sin firmar

# ---- Observabilidad (Fase 6) ----
# https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=""        # [DIFERIDO]
SENTRY_AUTH_TOKEN=""             # para source maps en build
# https://posthog.com
NEXT_PUBLIC_POSTHOG_KEY=""       # [DIFERIDO]
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ---- Twilio WhatsApp (Fase 4) ----
TWILIO_ACCOUNT_SID=""            # [DIFERIDO]
TWILIO_AUTH_TOKEN=""             # [DIFERIDO]
TWILIO_WHATSAPP_FROM=""          # ej: whatsapp:+1415...

# ---- Pagos (Fase 2 post-MVP) ----
STRIPE_SECRET_KEY=""             # [DIFERIDO post-MVP]
STRIPE_WEBHOOK_SECRET=""         # [DIFERIDO post-MVP]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""   # [DIFERIDO post-MVP]
MERCADOPAGO_ACCESS_TOKEN=""      # [DIFERIDO post-MVP — LatAm]
DLOCAL_API_KEY=""                # [DIFERIDO post-MVP — LatAm]

# ---- Web Push (Fase 4 — PWA notifications Android) ----
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""  # [DIFERIDO]
VAPID_PRIVATE_KEY=""             # [DIFERIDO]
VAPID_SUBJECT="mailto:mimathonline@gmail.com"

# ---- Feature flags ----
NEXT_PUBLIC_ENABLE_AI_TUTOR="false"           # se activa en Fase 5
NEXT_PUBLIC_ENABLE_PAYMENTS="false"           # se activa post-MVP
NEXT_PUBLIC_ENABLE_LEAGUES="false"            # se activa en Fase 4
NEXT_PUBLIC_ENABLE_WHATSAPP_NOTIFS="false"    # se activa en Fase 4
NEXT_PUBLIC_MAINTENANCE_MODE="false"

# ---- Internacionalización ----
NEXT_PUBLIC_DEFAULT_LOCALE="es"
NEXT_PUBLIC_SUPPORTED_LOCALES="es,en"         # 'pt' se agrega en Fase 2-post

# ---- Dev / debug ----
NODE_ENV="development"
LOG_LEVEL="info"                              # debug | info | warn | error
