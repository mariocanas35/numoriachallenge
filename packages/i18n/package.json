{
  "name": "@numoria/i18n",
  "version": "0.0.0",
  "private": true,
  "description": "Numoria i18n: locales, country mapping LatAm, pricing helpers, datetime formatters, mensajes ES/EN (PT preparado).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./messages/*": "./messages/*",
    "./config": "./src/config.ts",
    "./country": "./src/country-config.ts",
    "./pricing": "./src/pricing.ts",
    "./datetime": "./src/datetime.ts",
    "./detect": "./src/detect.ts"
  },
  "files": ["src", "messages"],
  "scripts": {
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@numoria/config": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
