# ============================================
# Numoria Challenge — .gitignore
# ============================================

# --- Dependencias ---
node_modules/
.pnp
.pnp.js
.pnp.cjs
.yarn/install-state.gz

# --- Builds y outputs ---
dist/
build/
out/
.next/
.turbo/
.expo/
.expo-shared/
*.tsbuildinfo
next-env.d.ts

# --- Env y secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# --- Supabase ---
supabase/.branches/
supabase/.temp/
supabase/.env
supabase/migrations/.dev/

# --- Python (microservicio grading) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/
.python-version

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Coverage / testing ---
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# --- IDE / Editores ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Vercel / Cloudflare ---
.vercel
.wrangler/

# --- Expo / EAS ---
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# --- Mobile artifacts ---
android/app/build/
android/.gradle/
ios/build/
ios/Pods/
*.apk
*.aab
*.ipa

# --- Misc ---
*.tmp
*.tgz
*.tar.gz
.cache/
.parcel-cache/
*.local

# --- Generated assets/types ---
packages/database/src/types.gen.ts

# --- Debug certificates / local AI cache ---
.claude/
.anthropic/
.openai-cache/
